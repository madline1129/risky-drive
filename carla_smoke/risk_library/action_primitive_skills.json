{
  "version": "0.1",
  "description": "Parameter-filling skills for L4 PlanAgent. Each skill defines how to instantiate one action primitive before OpenCode sees it.",
  "skills": [
    {
      "id": "front_vehicle_brake_after_trigger",
      "actor_role": "front_vehicle",
      "primary_actor_kinds": ["vehicle"],
      "spawn_semantics": {
        "relative_longitudinal_m": {"min": 5.0, "max": 35.0, "meaning": "front of ego"},
        "abs_relative_lateral_m": {"min": 0.0, "max": 2.2, "meaning": "same lane or near same lane"},
        "must_not_be_behind_ego": true
      },
      "required_action_fields": ["front_initial_speed_mps", "target_speed_mps", "brake_intensity", "trigger_frame", "direction.longitudinal_m", "direction.lateral_m"],
      "parameter_rules": [
        "direction.longitudinal_m must equal the selected/generated front vehicle relative_longitudinal_m.",
        "direction.lateral_m must equal the selected/generated front vehicle relative_lateral_m.",
        "front_initial_speed_mps should use the actor current speed if available, otherwise use 8.0.",
        "target_speed_mps should be 0.0 for hard brake; brake_intensity should be 1.0."
      ],
      "fallback_when_no_l0_actor_matches": {
        "source": "generated_object",
        "relative_longitudinal_m": 14.0,
        "relative_lateral_m": 0.0,
        "kind": "vehicle",
        "type_id": "vehicle.nissan.micra"
      }
    },
    {
      "id": "front_vehicle_slow_or_stop",
      "actor_role": "front_vehicle",
      "primary_actor_kinds": ["vehicle"],
      "spawn_semantics": {
        "relative_longitudinal_m": {"min": 5.0, "max": 35.0, "meaning": "front of ego"},
        "abs_relative_lateral_m": {"min": 0.0, "max": 2.2, "meaning": "same lane or near same lane"},
        "must_not_be_behind_ego": true
      },
      "required_action_fields": ["target_speed_mps", "trigger_frame", "direction.longitudinal_m", "direction.lateral_m"],
      "parameter_rules": [
        "Use a low target speed between 0.0 and 2.0 m/s.",
        "Keep lateral direction at 0.0 relative to the lane."
      ],
      "fallback_when_no_l0_actor_matches": {
        "source": "generated_object",
        "relative_longitudinal_m": 12.0,
        "relative_lateral_m": 0.0,
        "kind": "vehicle",
        "type_id": "vehicle.nissan.micra"
      }
    },
    {
      "id": "vru_cross_lateral_into_path",
      "actor_role": "vulnerable_actor",
      "primary_actor_kinds": ["pedestrian", "walker", "cyclist"],
      "spawn_semantics": {
        "relative_longitudinal_m": {"min": 4.0, "max": 20.0, "meaning": "front or near-front of ego"},
        "abs_relative_lateral_m": {"min": 1.5, "max": 6.0, "meaning": "left/right side of ego lane"},
        "must_not_be_behind_ego": true
      },
      "required_action_fields": ["initial_speed_mps", "crossing_speed_mps", "target_relative_lateral_m", "trigger_frame", "direction.longitudinal_m", "direction.lateral_m"],
      "parameter_rules": [
        "Do not select an L0 pedestrian behind ego for a forward crossing event.",
        "direction.longitudinal_m must be positive and match the primary actor relative_longitudinal_m.",
        "direction.lateral_m must match the primary actor relative_lateral_m and preserve left/right side.",
        "target_relative_lateral_m should be 0.0 for entering ego lane.",
        "crossing_speed_mps should usually be 1.2 to 2.0."
      ],
      "fallback_when_no_l0_actor_matches": {
        "source": "generated_object",
        "relative_longitudinal_m": 10.0,
        "relative_lateral_m": -3.5,
        "kind": "pedestrian",
        "type_id": "walker.pedestrian.0012"
      }
    },
