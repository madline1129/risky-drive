    {
      "id": "sudden_night_visibility_loss",
      "family": "weather_visibility_risk",
      "legacy_scenario_type": "weather_visibility_change",
      "primary_action_primitive_id": "weather_shift_to_night",
      "actor_kinds": ["ego"],
      "keywords": ["天气", "黑夜", "夜间", "光照", "可见度", "视距", "突然变暗"],
      "match": {},
      "acceptance": {"weather_profile_in_options": ["clear_night", "hard_rain_night", "hard_rain_sunset", "dust_storm"], "visibility_degraded": true}
    }
  ],
  "action_primitives": [
    {
      "id": "front_vehicle_brake_after_trigger",
      "actor_role": "front_vehicle",
      "motion_frame": "lane_following",
      "front_initial_speed_mps": 8.0,
      "target_speed_mps": 0.0,
      "brake_intensity": 1.0,
      "front_action_variant_options": ["hard_brake", "reverse_toward_ego_if_ego_speed_low"],
      "trigger_frame": 30,
      "trigger_seconds": 1.5,
      "direction": {"frame": "ego_local", "longitudinal_m": 14.0, "lateral_m": 0.0, "heading_delta_deg": 0.0},
      "stop_condition": "hard_stop_or_timeout",
      "acceptance_checks": ["front_vehicle_speed_drop", "front_vehicle_initially_ahead"]
    },
    {
      "id": "front_vehicle_slow_or_stop",
      "controlled_actor_role": "front_vehicle",
      "motion_frame": "lane_following",
      "velocity_vector": {"speed_policy": "hard_stop_or_reverse_if_ego_speed_low"},
      "direction_policy": "keep_lane",
      "target_speed_mps": 0.0,
      "brake_intensity": 1.0,
      "front_action_variant_options": ["hard_brake", "reverse_toward_ego_if_ego_speed_low"],
      "stop_condition": "hard_stop_or_timeout",
      "acceptance_checks": ["front_vehicle_initially_ahead", "front_distance_change"]
    },
    {
      "id": "vru_cross_lateral_into_path",
      "controlled_actor_role": "vulnerable_actor",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "longitudinal_policy": "maintain_or_reduce_distance", "speed_policy": "aggressive_crossing"},
      "direction_policy": "reduce_abs_lateral_to_ego",
      "crossing_speed_mps": 2.8,
      "target_relative_lateral_m": 0.0,
      "stop_condition": "reached_ego_lane_or_timeout",
      "acceptance_checks": ["vulnerable_actor_moves_after_trigger", "vulnerable_actor_moves_toward_ego_lane", "vulnerable_actor_approaches_ego"]
    },
    {
      "id": "vru_move_longitudinal_in_path",
      "controlled_actor_role": "vulnerable_actor",
      "motion_frame": "ego_local",
      "velocity_vector": {"longitudinal_direction": "toward_conflict_point", "lateral_policy": "enter_or_remain_near_ego_lane", "speed_policy": "aggressive_intrusion"},
      "direction_policy": "reduce_distance_to_ego_or_conflict_point",
      "speed_mps": 2.8,
      "stop_condition": "min_distance_or_timeout",
      "acceptance_checks": ["vulnerable_actor_moves_after_trigger", "vulnerable_actor_approaches_ego"]
    },
    {
      "id": "vru_emerge_from_occlusion_into_path",
      "controlled_actor_role": "vulnerable_actor",
      "motion_frame": "ego_local",
      "velocity_vector": {"direction": "from_occluder_toward_ego_path", "speed_policy": "aggressive_emerge"},
      "direction_policy": "enter_ego_path_from_occluded_side",
      "emerge_speed_mps": 2.8,
      "target_relative_lateral_m": 0.0,
      "stop_condition": "visible_in_ego_path_or_timeout",
      "acceptance_checks": ["vulnerable_actor_moves_after_trigger", "vulnerable_actor_close_enough"]
    },
    {
      "id": "side_vehicle_cut_in_to_ego_lane",
      "controlled_actor_role": "side_vehicle",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "longitudinal_policy": "forward", "lateral_speed_policy": "aggressive_cut_in"},
      "direction_policy": "reduce_abs_lateral_to_ego",
      "lateral_speed_mps": 1.5,
      "target_relative_lateral_abs_m": 0.5,
      "stop_condition": "reached_target_lateral_or_timeout",
      "acceptance_checks": ["side_vehicle_enters_ego_lane"]
    },
    {
      "id": "side_vehicle_drift_toward_ego_lane",
      "controlled_actor_role": "side_vehicle",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "lateral_speed_policy": "aggressive_intrusion"},
      "direction_policy": "reduce_abs_lateral_to_ego",
      "lateral_speed_mps": 1.2,
      "target_relative_lateral_abs_m": 0.5,
      "stop_condition": "reached_target_lateral_or_timeout",
      "acceptance_checks": ["side_vehicle_enters_ego_lane"]
    },
    {
      "id": "cross_vehicle_run_red_light_into_ego_path",
      "controlled_actor_role": "side_vehicle",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "longitudinal_policy": "toward_conflict_point", "speed_policy": "red_light_violation"},
      "direction_policy": "cross_intersection_into_ego_path",
      "lateral_speed_mps": 2.2,
      "target_relative_lateral_abs_m": 0.3,
      "traffic_signal_violation": "red_light_runner",
      "stop_condition": "entered_ego_path_or_timeout",
      "acceptance_checks": ["side_vehicle_enters_ego_lane", "min_distance_to_ego"]
    },
    {
      "id": "cross_vehicle_fail_to_yield_into_ego_path",
      "controlled_actor_role": "side_vehicle",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "longitudinal_policy": "toward_conflict_point", "speed_policy": "fail_to_yield_intrusion"},
      "direction_policy": "cross_intersection_into_ego_path",
      "lateral_speed_mps": 2.0,
      "target_relative_lateral_abs_m": 0.4,
      "stop_condition": "entered_ego_path_or_timeout",
      "acceptance_checks": ["side_vehicle_enters_ego_lane", "min_distance_to_ego"]
    },
    {
      "id": "oncoming_vehicle_turn_across_ego_path",
      "controlled_actor_role": "side_vehicle",
      "motion_frame": "ego_local",
      "velocity_vector": {"lateral_direction": "toward_ego_lane", "longitudinal_policy": "turn_across_ego_path", "speed_policy": "aggressive_turn_across"},
