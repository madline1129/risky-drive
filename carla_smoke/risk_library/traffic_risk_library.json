      "legacy_scenario_type": "vulnerable_actor_intrusion",
      "primary_action_primitive_id": "vru_emerge_from_occlusion_into_path",
      "actor_kinds": ["pedestrian", "walker", "cyclist"],
      "keywords": ["行人", "骑行", "遮挡", "盲区", "A柱", "突然出现", "未观察到"],
      "match": {"relative_positions": ["front-left", "front-right", "left", "right"], "max_longitudinal_m": 25.0},
      "acceptance": {"actor_motion_m_min": 2.0, "min_distance_to_ego_m_max": 6.0}
    },
    {
      "id": "side_vehicle_cut_in",
      "family": "side_vehicle_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "side_vehicle_cut_in_to_ego_lane",
      "actor_kinds": ["vehicle"],
      "keywords": ["侧车", "侧方", "变道", "切入", "并线", "车道空间"],
      "match": {"relative_positions": ["front-left", "front-right", "left", "right"], "max_abs_lateral_m": 6.0},
      "acceptance": {"relative_lateral_delta_m_min": 2.0, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "side_vehicle_drift_intrusion",
      "family": "side_vehicle_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "side_vehicle_drift_toward_ego_lane",
      "actor_kinds": ["vehicle"],
      "keywords": ["侧车", "偏移", "压线", "侵入", "车道空间"],
      "match": {"relative_positions": ["front-left", "front-right", "left", "right"], "max_abs_lateral_m": 6.0},
      "acceptance": {"relative_lateral_delta_m_min": 1.5, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "static_obstacle_in_path",
      "family": "obstacle_risk",
      "legacy_scenario_type": "road_obstacle_intrusion",
      "primary_action_primitive_id": "static_obstacle_blocking_path",
      "actor_kinds": ["obstacle", "static", "vehicle"],
      "keywords": ["障碍", "静止", "停在", "阻挡", "路径"],
      "match": {"relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 20.0},
      "acceptance": {"min_obstacle_distance_to_ego_m_max": 8.0}
    },
    {
      "id": "cargo_drop_into_path",
      "family": "cargo_payload_risk",
      "legacy_scenario_type": "cargo_drop",
      "primary_action_primitive_id": "cargo_drop_or_slide_into_path",
      "actor_kinds": ["payload", "cargo", "object", "vehicle"],
      "keywords": ["货物", "掉落", "滑落", "飞出", "载荷", "绳索"],
      "match": {"relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 35.0},
      "acceptance": {"payload_count_min": 1, "payload_motion_m_min": 1.5}
    },
    {
      "id": "ego_continue_toward_hazard",
      "family": "ego_action_risk",
      "legacy_scenario_type": "ego_action_risk",
      "primary_action_primitive_id": "ego_continue_without_braking",
      "actor_kinds": ["ego"],
      "hazard_actor_kinds": ["vehicle", "pedestrian", "walker", "cyclist", "obstacle"],
      "keywords": ["未减速", "继续", "直行", "未观察到", "反应延迟", "碰撞不可避免"],
      "match": {"hazard_relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 20.0},
      "acceptance": {"ego_speed_near_trigger_min": 2.0, "distance_to_hazard_decrease_min": 1.0, "min_distance_to_hazard_m_max": 3.0}
    },
    {
      "id": "ego_insufficient_braking",
      "family": "ego_action_risk",
      "legacy_scenario_type": "ego_action_risk",
      "primary_action_primitive_id": "ego_late_or_insufficient_braking",
      "actor_kinds": ["ego"],
      "hazard_actor_kinds": ["vehicle", "pedestrian", "walker", "cyclist", "obstacle"],
      "keywords": ["制动不足", "刹车不足", "反应不及", "距离不足"],
      "match": {"hazard_relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 25.0},
      "acceptance": {"ego_speed_near_trigger_min": 2.0, "distance_to_hazard_decrease_min": 1.0}
    },
    {
      "id": "lead_turn_reveals_vru",
      "family": "rare_composite_risk",
      "legacy_scenario_type": "vulnerable_actor_intrusion",
      "primary_action_primitive_id": "vru_emerge_from_occlusion_into_path",
      "actor_kinds": ["pedestrian", "walker", "cyclist"],
      "keywords": ["前车", "左转", "遮挡", "行人", "暴露", "出现", "复合", "罕见"],
      "match": {"relative_positions": ["front-left", "front-right", "left", "right", "front"], "max_longitudinal_m": 25.0},
      "acceptance": {"actor_motion_m_min": 2.0, "min_distance_to_ego_m_max": 6.0}
    },
    {
      "id": "rare_side_vehicle_unexpected_intrusion",
      "family": "rare_composite_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "side_vehicle_cut_in_to_ego_lane",
      "actor_kinds": ["vehicle"],
      "keywords": ["侧方", "横向", "掉头", "逆行", "非典型", "侵入", "罕见"],
      "match": {"relative_positions": ["front-left", "front-right", "left", "right"], "max_abs_lateral_m": 7.0},
      "acceptance": {"relative_lateral_delta_m_min": 2.0, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "rare_object_unexpected_intrusion",
      "family": "rare_composite_risk",
      "legacy_scenario_type": "road_obstacle_intrusion",
      "primary_action_primitive_id": "static_obstacle_blocking_path",
      "actor_kinds": ["obstacle", "static", "payload", "object", "vehicle"],
      "keywords": ["异物", "障碍", "货物", "掉落", "散落", "非典型", "罕见"],
      "match": {"relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 25.0},
      "acceptance": {"min_obstacle_distance_to_ego_m_max": 8.0}
    },
    {
      "id": "cross_traffic_red_light_intrusion",
      "family": "intersection_signal_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "cross_vehicle_run_red_light_into_ego_path",
      "actor_kinds": ["vehicle"],
      "keywords": ["路口", "十字路口", "红灯", "绿灯", "信号灯", "闯红灯", "横向来车", "右侧来车", "左侧来车", "cross traffic", "red light"],
      "match": {"relative_positions": ["left", "right", "front-left", "front-right"], "max_longitudinal_m": 30.0, "min_abs_lateral_m": 2.0, "max_abs_lateral_m": 18.0, "road_context": ["signalized_intersection", "traffic_light_present"]},
      "acceptance": {"relative_lateral_delta_m_min": 2.0, "min_abs_relative_lateral_m_max": 0.8, "min_distance_to_ego_m_max": 6.0}
    },
    {
      "id": "opposing_left_turn_across_path",
      "family": "intersection_signal_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "oncoming_vehicle_turn_across_ego_path",
      "actor_kinds": ["vehicle"],
      "keywords": ["路口", "对向左转", "抢行", "无保护左转", "左转穿越", "对向车", "turn across path"],
      "match": {"relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 35.0, "road_context": ["intersection"]},
      "acceptance": {"relative_lateral_delta_m_min": 1.5, "min_distance_to_ego_m_max": 6.0}
    },
    {
      "id": "side_road_vehicle_fails_to_yield",
      "family": "intersection_signal_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "cross_vehicle_fail_to_yield_into_ego_path",
