      "keywords": ["让行", "支路", "侧路", "路口", "未让行", "横向", "冲出", "stop sign", "yield"],
      "match": {"relative_positions": ["left", "right", "front-left", "front-right"], "max_longitudinal_m": 30.0, "min_abs_lateral_m": 2.0, "max_abs_lateral_m": 18.0, "road_context": ["intersection"]},
      "acceptance": {"relative_lateral_delta_m_min": 2.0, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "oncoming_vehicle_encroaches_ego_lane",
      "family": "oncoming_vehicle_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "oncoming_vehicle_encroach_ego_lane",
      "actor_kinds": ["vehicle"],
      "keywords": ["对向车", "逆向", "越线", "占道", "中心线", "迎面", "oncoming", "head-on"],
      "match": {"relative_positions": ["front", "front-left", "front-right"], "max_longitudinal_m": 40.0, "max_abs_lateral_m": 6.0},
      "acceptance": {"relative_lateral_delta_m_min": 1.5, "min_abs_relative_lateral_m_max": 0.8, "min_distance_to_ego_m_max": 8.0}
    },
    {
      "id": "merge_vehicle_forced_entry",
      "family": "merge_yield_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "merge_vehicle_force_into_ego_lane",
      "actor_kinds": ["vehicle"],
      "keywords": ["汇入", "并道", "匝道", "入口", "加塞", "侧方", "merge", "ramp"],
      "match": {"relative_positions": ["left", "right", "front-left", "front-right"], "max_longitudinal_m": 30.0, "min_abs_lateral_m": 2.0, "max_abs_lateral_m": 8.0},
      "acceptance": {"relative_lateral_delta_m_min": 1.8, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "parked_or_driveway_vehicle_pulls_out",
      "family": "merge_yield_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "driveway_vehicle_pull_out_into_ego_path",
