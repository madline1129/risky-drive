      "match": {"relative_positions": ["left", "right", "front-left", "front-right"], "max_longitudinal_m": 25.0, "min_abs_lateral_m": 2.0, "max_abs_lateral_m": 10.0},
      "acceptance": {"relative_lateral_delta_m_min": 2.0, "min_abs_relative_lateral_m_max": 0.8}
    },
    {
      "id": "illegal_u_turn_into_ego_path",
      "family": "wrong_way_u_turn_risk",
      "legacy_scenario_type": "side_vehicle_intrusion",
      "primary_action_primitive_id": "vehicle_illegal_u_turn_into_ego_path",
      "actor_kinds": ["vehicle"],
      "keywords": ["掉头", "U形", "逆行", "横摆", "突然转向", "u-turn", "wrong-way"],
